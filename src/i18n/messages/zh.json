  "about": {
    "metadata": {
      "title": "关于 Petdex — 适用于 Codex 的动画伙伴",
      "title__fixme": true,
      "description": "Petdex 是一个面向 Codex 的开源动画伙伴图库。浏览目录、用一条命令安装，或提交你自己的作品。",
