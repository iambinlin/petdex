# petdex env vars.
#
# THREE PATHS to run locally — pick one:
#
#   1. bun run dev:mock     — zero credentials, in-process Postgres + fake Clerk.
#                             Good for tweaking UI / copy / i18n. Slower HMR.
#                             You can ignore this whole file.
#
#   2. bun run dev:docker   — Postgres + Redis in containers + shared OSS Clerk.
#                             Good for testing DB queries, auth flows, or anything
#                             that touches a real backend. Defaults are committed
#                             in .env.dev — copy any value here only if you want
#                             to override it for yourself.
#
#   3. bun run dev          — your own everything. For maintainers.
#                             Fill in the values below from your private accounts.
#
# Anything you set in .env.local wins over .env.dev. Most contributors
# never need to touch this file.

# Core
DATABASE_URL=

# Clerk (frontend public, backend secret)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# AI / similarity / review / autotag / sound
# Embeddings and automated review use Vercel AI Gateway via AI SDK.
AI_GATEWAY_API_KEY=
ELEVENLABS_API_KEY=
FFMPEG_BIN=

# Redis / rate-limit / cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email notifications
RESEND_API_KEY=
RESEND_FROM=
PETDEX_OWNER_EMAIL=
PETDEX_ADMIN_NOTIFY_EMAIL=

# Admin
PETDEX_ADMIN_USER_IDS=
NEXT_PUBLIC_PETDEX_ADMIN_USER_IDS=

# Optional app URLs
PETDEX_ALL_PETS_PACK_URL=
VERCEL_URL=

# CLI / script-related
CLERK_CLI_ISSUER=
PETDEX_CLERK_APP=
PETDEX_CLERK_INSTANCE=
PETDEX_URL=
CLERK_ISSUER=
CLERK_OAUTH_CLIENT_ID=
