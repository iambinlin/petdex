# Shared dev defaults. Committed to the repo. Run `bun run dev:docker`
# and these values let the app talk to the local container stack and a
# shared Clerk dev instance.
#
# Anything you set in your own .env.local will override these (the
# dev:docker script loads .env.dev first, then .env.local on top, so
# personal credentials win without you needing to wipe this file).
#
# WHAT YOU NEED TO BRING YOURSELF:
#   - Nothing for browse / sign-in / submission flows
#   - OPENAI_API_KEY only if you're testing autotag, similarity, or
#     vibe search (everything else falls back gracefully)
#   - R2 credentials only if you want real upload (otherwise web
#     uploads return a 500 in dev — that's fine)

# Postgres (docker compose service)
DATABASE_URL=postgresql://petdex:petdex@127.0.0.1:54320/petdex

# Upstash REST surface (srh container in front of local redis)
UPSTASH_REDIS_REST_URL=http://127.0.0.1:8079
UPSTASH_REDIS_REST_TOKEN=petdex-dev-token

# Clerk: shared dev instance for petdex (maximum-hen-72). The
# publishable key is safe to commit — it's a public client identifier
# Clerk hands out for use in browser bundles. The secret key is NOT
# in this file. Maintainers and trusted contributors share it via
# 1Password or grab it from the Clerk dashboard, then drop it into
# .env.dev.local (gitignored) as CLERK_SECRET_KEY.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_bWF4aW11bS1oZW4tNzIuY2xlcmsuYWNjb3VudHMuZGV2JA

# Default admin user id for scripts that read PETDEX_ADMIN_USER_IDS.
# Empty by default; set your own Clerk dev user_xxx id once you sign in.
PETDEX_ADMIN_USER_IDS=
NEXT_PUBLIC_PETDEX_ADMIN_USER_IDS=

# R2 — pointed at non-routable host so accidental uploads error fast
# instead of silently writing to prod. Override in .env.local if you
# really want to test uploads against a real bucket.
R2_ACCOUNT_ID=devnull
R2_ACCESS_KEY_ID=devnull
R2_SECRET_ACCESS_KEY=devnull
R2_BUCKET=petdex-dev
R2_PUBLIC_BASE=http://127.0.0.1:0

# Optional integrations: leave blank in dev. The app's own code paths
# already check for these and skip the call when missing.
RESEND_API_KEY=
RESEND_FROM=
PETDEX_OWNER_EMAIL=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
