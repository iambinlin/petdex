# PETDEX_MOCK=1 — local QA env for external contributors. No real
# credentials needed. Boot with `bun run dev:mock` and hit
# http://localhost:3000.

PETDEX_MOCK=1

# Placeholders so anything that reads process.env directly doesn't crash.
# The real values aren't used (mock shims short-circuit before any
# network call would happen).
DATABASE_URL=postgresql://mock@127.0.0.1:0/mock
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_mock
CLERK_SECRET_KEY=sk_test_mock
UPSTASH_REDIS_REST_URL=https://mock.invalid
UPSTASH_REDIS_REST_TOKEN=mock
R2_ACCOUNT_ID=mock
R2_ACCESS_KEY_ID=mock
R2_SECRET_ACCESS_KEY=mock
R2_BUCKET=petdex-mock
R2_PUBLIC_BASE=https://mock.invalid
RESEND_API_KEY=re_mock
RESEND_FROM=mock@petdex.local
PETDEX_OWNER_EMAIL=mock@petdex.local
OPENAI_API_KEY=sk-mock
ELEVENLABS_API_KEY=mock
PETDEX_ADMIN_USER_IDS=user_mock_contributor
NEXT_PUBLIC_PETDEX_ADMIN_USER_IDS=user_mock_contributor
